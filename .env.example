# ─────────────────────────────────────────────
# Datafly Environment Configuration
# ─────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────

# Anthropic
#ANTHROPIC_API_KEY=your_anthropic_key_here
# Options: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5
#DATAFLY_ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter
OPENROUTER_API_KEY=
# Options: anthropic/claude-sonnet-4-6 | openai/gpt-4o | google/gemini-2.0-flash-001 | meta-llama/llama-3.3-70b-instruct
DATAFLY_OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# ── Context Storage ───────────────────────────

DATAFLY_CONTEXT_BACKEND=hybrid
DATAFLY_CONTEXT_YAML=datafly/context/context.yaml
DATAFLY_CONTEXT_DB_URL=postgresql://datafly:datafly@localhost:5433/datafly_context

# ── API Server ────────────────────────────────

DATAFLY_API_HOST=0.0.0.0
DATAFLY_API_PORT=8000
DATAFLY_MCP_PORT=8080
DATAFLY_LOG_LEVEL=INFO
